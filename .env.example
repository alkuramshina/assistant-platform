# Image / deploy
REGISTRY_IMAGE=nanobot-enterprise-pilot
IMAGE_TAG=dev
APP_UID=1000
APP_GID=1000
TZ=UTC
NANOBOT_LOG_LEVEL=INFO
NANOBOT_GATEWAY_PORT=18790

# Agent defaults. These are already selected for the local Telegram/OpenRouter smoke test.
DEFAULT_PROVIDER=openrouter
DEFAULT_MODEL=openrouter/free
SYSTEM_PROMPT=You are a concise and reliable work assistant for internal work tasks.

# Access control. Required for the real Telegram smoke test; replace the example ID locally.
CHANNEL_ALLOW_FROM=123456789
CHANNEL_GROUP_POLICY=mention
CHANNEL_GROUP_ALLOW_FROM=

# Provider secret sources. Compose mounts these as files under /run/secrets.
# Required for the real smoke test: OPENROUTER_API_KEY.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VLLM_API_BASE=
VLLM_API_KEY=dummy

# Channel choice. Telegram is the selected local smoke-test channel.
CHANNEL_TYPE=telegram

# Telegram secret source. Compose mounts this as /run/secrets/telegram_token.
# Required for the real smoke test: TELEGRAM_TOKEN.
TELEGRAM_ENABLED=true
TELEGRAM_TOKEN=

# Slack
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Feishu
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
