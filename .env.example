# Image / deploy
REGISTRY_IMAGE=nanobot-enterprise-pilot
IMAGE_TAG=dev
APP_UID=1000
APP_GID=1000
TZ=UTC
NANOBOT_LOG_LEVEL=INFO
NANOBOT_GATEWAY_PORT=18790

# Agent
DEFAULT_PROVIDER=openrouter
DEFAULT_MODEL=openai/gpt-4.1-mini
SYSTEM_PROMPT=You are a concise and reliable work assistant for internal work tasks.

# Access control
CHANNEL_ALLOW_FROM=123456789
CHANNEL_GROUP_POLICY=mention
CHANNEL_GROUP_ALLOW_FROM=

# Providers
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VLLM_API_BASE=
VLLM_API_KEY=dummy

# Channel choice
CHANNEL_TYPE=telegram

# Telegram
TELEGRAM_ENABLED=true
TELEGRAM_TOKEN=

# Slack
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Feishu
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Backup
RESTIC_REPOSITORY=s3:https://s3.example.com/nanobot-pilot
RESTIC_PASSWORD=
BACKUP_ACCESS_KEY_ID=
BACKUP_SECRET_ACCESS_KEY=
BACKUP_REGION=us-east-1
